{
    "name":"boxlang",
    "app":{
        "cfengine":"boxlang@be",
        "libDirs":"c:\\CFusionExtra\\java,c:\\CFusionExtra\\java2021",
        "showErrors":true
    },
    "dockEnable":true,
    "trayEnable":true,
    "json":{
        "ansiColors":{
            "constant":"48B9FF"
        }
    },
    "customTagPaths":[
        {
            "physical":"c:\\CFusionExtra\\customtags",
            "primary":"physical"
        }
    ],
    "jvm":{
        "javaHome":"C:\\Program Files\\Java\\jdk-24",
        "args":[
            "-D:javax.xml.accessExternalDTD=''",
            "-D:javax.xml.accessExternalSchema=''",
            "-D:javax.xml.accessExternalStylesheet=''"
        ],
        "javaVersion":"openjdk21"
    },
    "web":{
        "host":"0.0.0.0",
        "hostAlias":"boxlang.local",
        "webroot":"www",
        "directoryBrowsing":true,
        "accessLogEnable":true,
        "blockCFAdmin":false,
        "blockSensitivePaths":true,
        "welcomeFiles":"index.cfm,index.html,index.htm",
        "gzipEnable":true,
        "blockFlashRemoting":true,
        "rewrites":{
            "enable":true
        },
        "aliases":{
            "/_scriptsGlobal":"c:\\Commandbox\\www\\_scriptsGlobal"
        },
        "HTTP":{
            "enable":true,
            "port":4000
        },
        "mimeTypes":{
            "heic":"image/heic"
        }
    },
    "debug":true,
    "trace":false,
    "console":false,
    "profile":"development",
    "openBrowser":true,
    "openBrowserURL":"http://boxlang.local:4000/",
    "boxlang":{
        "compatibility":{
            "adobe":true
        }
    }
}
