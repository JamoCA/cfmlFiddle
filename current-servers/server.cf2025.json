{
    "name":"cf2025",
    "app":{
        "cfengine":"adobe@2025",
        "libDirs":"c:\\CFusionExtra\\java,c:\\CFusionExtra\\java2021"
    },
    "dockEnable":true,
    "trayEnable":true,
    "json":{
        "ansiColors":{
            "constant":"48B9FF"
        }
    },
    "customTagPaths":[
        {
            "physical":"c:\\CFusionExtra\\customtags",
            "primary":"physical"
        }
    ],
    "jvm":{
        "javaHome":"C:\\Program Files\\Java\\jdk-24",
        "args":[
            "-D:javax.xml.accessExternalDTD=''",
            "-D:javax.xml.accessExternalSchema=''",
            "-D:javax.xml.accessExternalStylesheet=''"
        ]
    },
    "web":{
        "host":"0.0.0.0",
        "hostAlias":"cf2025.local",
        "webroot":"www",
        "directoryBrowsing":true,
        "accessLogEnable":true,
        "blockCFAdmin":false,
        "blockSensitivePaths":true,
        "welcomeFiles":"index.cfm,index.html,index.htm",
        "gzipEnable":true,
        "blockFlashRemoting":true,
        "rewrites":{
            "enable":true
        },
        "aliases":{
            "/_scriptsGlobal":"c:\\Commandbox\\www\\_scriptsGlobal"
        },
        "HTTP":{
            "enable":true,
            "port":2025
        },
        "mimeTypes":{
            "heic":"image/heic"
        }
    },
    "debug":true,
    "trace":false,
    "console":false,
    "profile":"development",
    "openBrowser":true,
    "openBrowserURL":"http://cf2025.local:2025/",
    "scripts":{
        "onServerInitialInstall":"cfpm install caching debugger"
    }
}
