{
    "name":"cf2023",
    "app":{
        "cfengine":"adobe@2023",
        "libDirs":"c:\\CFusionExtra\\java,c:\\CFusionExtra\\java2021"
    },
    "dockEnable":true,
    "trayEnable":true,
    "json":{
        "ansiColors":{
            "constant":"48B9FF"
        }
    },
    "customTagPaths":[
        {
            "physical":"c:\\CFusionExtra\\customtags",
            "primary":"physical"
        }
    ],
    "jvm":{
        "args":[
            "-D:javax.xml.accessExternalDTD=''",
            "-D:javax.xml.accessExternalSchema=''",
            "-D:javax.xml.accessExternalStylesheet=''",
            "--add-opens=java.base/sun.nio.cs=ALL-UNNAMED",
            "--add-opens=java.naming/javax.naming.directory=ALL-UNNAMED",
            "--add-opens=java.base/java.util.stream=ALL-UNNAMED"
        ]
    },
    "web":{
        "host":"0.0.0.0",
        "hostAlias":"cf2023.local",
        "webroot":"www",
        "directoryBrowsing":true,
        "accessLogEnable":true,
        "blockCFAdmin":false,
        "blockSensitivePaths":true,
        "welcomeFiles":"index.cfm,index.html,index.htm",
        "gzipEnable":true,
        "blockFlashRemoting":true,
        "rewrites":{
            "enable":true
        },
        "aliases":{
            "/_scriptsGlobal":"c:\\Commandbox\\www\\_scriptsGlobal"
        },
        "HTTP":{
            "enable":true,
            "port":2023
        },
        "mimeTypes":{
            "heic":"image/heic"
        }
    },
    "debug":true,
    "trace":false,
    "console":false,
    "profile":"development",
    "openBrowser":true,
    "openBrowserURL":"http://cf2023.local:2023/",
    "scripts":{
        "onServerInitialInstall":"cfpm install caching debugger"
    }
}
