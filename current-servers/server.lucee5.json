{
    "name":"lucee5",
    "app":{
        "cfengine":"lucee@5",
        "libDirs":"c:\\CFusionExtra\\java,c:\\CFusionExtra\\java2021"
    },
    "dockEnable":true,
    "trayEnable":true,
    "json":{
        "ansiColors":{
            "constant":"48B9FF"
        }
    },
    "customTagPaths":[
        {
            "physical":"c:\\CFusionExtra\\customtags",
            "primary":"physical"
        }
    ],
    "luceeConfig":{
        "customTagMappings":{
            "mapping":[
                {
                    "physical":"c:\\CFusionExtra\\customtags",
                    "primary":"physical",
                    "virtual":"/customtags",
                    "readonly":false
                }
            ]
        }
    },
    "jvm":{
        "javaHome":"C:\\CFusionExtra\\jdk\\jdk-11.0.25",
        "args":[
            "-D:javax.xml.accessExternalDTD=''",
            "-D:javax.xml.accessExternalSchema=''",
            "-D:javax.xml.accessExternalStylesheet=''"
        ]
    },
    "web":{
        "host":"0.0.0.0",
        "hostAlias":"lucee5.local",
        "webroot":"www",
        "directoryBrowsing":true,
        "accessLogEnable":true,
        "blockCFAdmin":false,
        "blockSensitivePaths":true,
        "welcomeFiles":"index.cfm,index.html,index.htm",
        "gzipEnable":true,
        "blockFlashRemoting":true,
        "rewrites":{
            "enable":true
        },
        "aliases":{
            "/_scriptsGlobal":"c:\\Commandbox\\www\\_scriptsGlobal"
        },
        "HTTP":{
            "enable":true,
            "port":3005
        },
        "mimeTypes":{
            "heic":"image/heic"
        }
    },
    "debug":true,
    "trace":false,
    "console":false,
    "profile":"development",
    "openBrowser":true,
    "openBrowserURL":"http://lucee5.local:3005/"
}
